# Set via Firebase CLI (never commit the real key):
#   firebase functions:secrets:set TWOFACTOR_API_KEY
#
# For local emulator, create functions/.secret.local:
#   TWOFACTOR_API_KEY=your_2factor_api_key
#
# 2Factor API docs: https://documenter.getpostman.com/view/301893/TWDamFGh

TWOFACTOR_API_KEY=
