EXPO_PUBLIC_FIREBASE_API_KEY=your_api_key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
EXPO_PUBLIC_FIREBASE_APP_ID=your_app_id
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id
EXPO_PUBLIC_FIREBASE_FUNCTIONS_REGION=asia-south1

# 2Factor.in SMS OTP (called directly from the app — no Cloud Functions)
EXPO_PUBLIC_TWOFACTOR_API_KEY=your_2factor_api_key
# Optional: approved OTP template name from 2Factor dashboard (required for many Indian numbers/DLT)
EXPO_PUBLIC_TWOFACTOR_TEMPLATE=

# Optional: Krushi Sarthi fungicide/insecticide lists (Firestore `products`)
# See products-firestore.README — https://console.firebase.google.com/project/krushisarthi-be143/firestore
EXPO_PUBLIC_CATALOG_FIREBASE_API_KEY=
EXPO_PUBLIC_CATALOG_FIREBASE_AUTH_DOMAIN=krushisarthi-be143.firebaseapp.com
EXPO_PUBLIC_CATALOG_FIREBASE_PROJECT_ID=krushisarthi-be143
EXPO_PUBLIC_CATALOG_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_CATALOG_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_CATALOG_FIREBASE_APP_ID=
