rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isChatMember(groupId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/chatGroups/$(groupId)/members/$(request.auth.uid));
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    match /sprayLogs/{logId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /fertilizerLogs/{logId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /irrigationLogs/{logId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /farmActivityLogs/{logId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /cropSchedules/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /costCatalog/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /products/{productId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /chatGroups/{groupId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();

      match /messages/{msgId} {
        allow read: if isChatMember(groupId);
        allow create: if isChatMember(groupId) && request.resource.data.userId == request.auth.uid;
        allow update, delete: if false;
      }

      match /members/{memberId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && request.auth.uid == memberId;
      }
    }
  }
}
